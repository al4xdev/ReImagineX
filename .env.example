# ComfyUI backend URL
COMFY_URL=http://127.0.0.1:8001

# Data directory for images and state
DATA_DIR=gallery_data

# OpenRouter API key (get yours at https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

